# ──────────────────────────────────────────────────────────────────────────────
# Flash Agent v3.0.0 – Configuration Template
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# For local overrides, create .env.local (takes priority over .env)
# ──────────────────────────────────────────────────────────────────────────────

# Agent
AGENT_NAME=flash-agent
LOG_LEVEL=INFO

# Kubernetes
K8S_NAMESPACE=default
K8S_NODE_IP=192.168.65.3

# LLM Gateway (LiteLLM Proxy)
OPENAI_BASE_URL=http://localhost:4000/v1
OPENAI_API_KEY=<your-api-key>
MODEL_ALIAS=auto-free

# MCP Servers
MCP_URLs=http://localhost:8086/mcp,http://localhost:8085/mcp
MCP_TIMEOUT=30

# OpenTelemetry (OTL Collector → Langfuse)
# Set endpoint to enable tracing, e.g.: http://localhost:4318/v1/traces
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=

# Langfuse (direct SDK client – optional, for richer metadata)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Storage – MCP interaction log file
MCP_INTERACTIONS_FILE=/app/logs/mcp_interactions.jsonl

# Chaos Context
# CHAOS_NAMESPACE: namespace where Litmus/Argo chaos resources are deployed
CHAOS_NAMESPACE=litmus
# TARGET_APP_NAME: target application name for pod matching
TARGET_APP_NAME=sock-shop
# MCP_INCLUDE_CHAOS_TOOLS: set to "false" for blind-observer mode
# When false, chaos-specific MCP tools (chaosengines, chaosresults,
# argo_workflows) are excluded from data collection and LLM prompts,
# preventing chaos experiment data from leaking into Langfuse traces.
MCP_INCLUDE_CHAOS_TOOLS=true

# Scan Behaviour
# TRACE_TAGS: comma-separated tags for tracing
TRACE_TAGS=flash-agent
# SCAN_INTERVAL: seconds between scans (0 = run once / CronJob mode)
SCAN_INTERVAL=300
SCAN_QUERY=Analyse the operational health of all workloads in Kubernetes namespace 'default'. Identify pod failures, restarts, resource pressure, and anomalies.

# ──────────────────────────────────────────────────────────────────────────────
# Mitigation (Phase 0–8) — closed-loop remediation
# ──────────────────────────────────────────────────────────────────────────────
# AGENT_MODE: "observe" (default, read-only) or "mitigate" (will execute soft
# actions and propose hard actions that pass 2-pass review).
AGENT_MODE=observe

# When AGENT_MODE=mitigate: either set AGENT_SCOPE_NAMESPACE (explicit scope)
# OR set MITIGATION_ALLOW_DISCOVERED_SCOPE=true to act on auto-discovered scope.
AGENT_SCOPE_NAMESPACE=
MITIGATION_ALLOW_DISCOVERED_SCOPE=false

# Number of independent reviewer passes for HARD actions. Default 2
# (justify + challenge). Both must approve.
MITIGATION_REVIEW_ITERS=2

# Audit JSONL log file. Records: classifications, gate decisions, episode
# transitions, reviewer verdicts, reconciliations. Empty = no audit log.
MITIGATION_AUDIT_PATH=

# Reviewer model. Reuses OPENAI_BASE_URL + OPENAI_API_KEY. The difference in
# model is the source of uncorrelated errors between proposer and reviewer.
# Recommendation: smaller / cheaper than MODEL_ALIAS. Empty = degraded mode
# (falls back to MODEL_ALIAS — reviewer errors correlate with proposer).
REVIEWER_MODEL_ALIAS=

# Action-class patterns. Each is a comma-separated regex list. Empty = use
# conservative defaults from policy/classifier.py. Patterns match against
# tool name AND description.
ACTION_PATTERNS_SOFT=
ACTION_PATTERNS_HARD=
ACTION_PATTERNS_VIOLENT=

# Persistent episode store. JSONL file — episodes + fingerprint snapshots.
# Empty = in-memory only (lost on agent restart).
AGENT_MEMORY_PATH=
MEMORY_TTL_DAYS=7
